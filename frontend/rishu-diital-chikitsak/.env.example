# =============================================================
# Digital Chikitsak — Frontend Environment Variables (Vite)
# =============================================================
# HOW TO USE:
#   Local dev  → Copy this file to .env and fill in your values
#   Render.com → Add each variable in:
#                Dashboard → Your Static Site → Environment → Add Environment Variable
#   Netlify    → Site Settings → Environment Variables
#   Vercel     → Project Settings → Environment Variables
#
# ALL variables MUST start with VITE_ to be accessible in the browser.
# NEVER put secret keys (API secrets, JWT secret) here — these are public.
# =============================================================


# ── SUPABASE ──────────────────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → API
# Use the "anon / public" key — this is safe to expose in frontend.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── CLOUDINARY ────────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
# VITE_CLOUDINARY_CLOUD_NAME : your cloud name (e.g. dtph7wv2h)
# VITE_CLOUDINARY_UPLOAD_PRESET : unsigned upload preset name
#   → Create at: Cloudinary Dashboard → Settings → Upload → Upload Presets
#   → Set signing mode to "Unsigned"
#   → Suggested name: chikitsak_unsigned

VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=chikitsak_unsigned

# NOTE: Never put CLOUDINARY_API_SECRET here — it must stay server-side only.


# ── BACKEND API URL ───────────────────────────────────────────
# Local dev  : http://localhost:5000/api
# Render.com : https://your-backend-service.onrender.com/api
#   → Replace with your actual Render backend URL after deploying the backend.

VITE_API_URL=https://your-backend-service.onrender.com/api


# =============================================================
# RENDER.COM DEPLOYMENT CHECKLIST (Static Site)
# =============================================================
# Service type  : Static Site
# Build command : npm install && npm run build
# Publish dir   : dist
#
# Required env vars on Render:
#   ✅ VITE_SUPABASE_URL
#   ✅ VITE_SUPABASE_PUBLISHABLE_KEY
#   ✅ VITE_CLOUDINARY_CLOUD_NAME
#   ✅ VITE_CLOUDINARY_UPLOAD_PRESET=chikitsak_unsigned
#   ✅ VITE_API_URL=https://your-backend.onrender.com/api
#
# IMPORTANT: On Render, env vars for static sites must be set
# BEFORE the build runs — they are baked into the JS bundle at build time.
#
# CORS: Make sure your Flask backend allows your Render frontend URL.
# The backend already has CORS(app, origins="*") so this is fine.
# =============================================================
