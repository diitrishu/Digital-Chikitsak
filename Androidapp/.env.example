# =============================================================
# Digital Chikitsak — Android App (Expo) Environment Variables
# =============================================================
# HOW TO USE:
#   Copy this file to .env and fill in your real values.
#   NEVER commit your actual .env file to git.
# =============================================================

# ── SUPABASE ──────────────────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_your_key_here

# ── CLOUDINARY ────────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
EXPO_PUBLIC_CLOUDINARY_CLOUD=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_PRESET=your_unsigned_upload_preset

# ── BACKEND URLS ──────────────────────────────────────────────
# For local dev: use your machine's LAN IP (run `ipconfig` on Windows)
# For production: use your deployed backend URL
EXPO_PUBLIC_API_URL=http://192.168.x.x:5050/api
EXPO_PUBLIC_PREDICTOR_URL=http://192.168.x.x:5001/api/v1
