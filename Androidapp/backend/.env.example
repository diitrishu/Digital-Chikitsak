# =============================================================
# Digital Chikitsak — Android Dedicated Backend Environment Variables
# =============================================================
# HOW TO USE:
#   Copy this file to .env and fill in your real values.
#   NEVER commit your actual .env file to git.
# =============================================================

# ── SUPABASE ──────────────────────────────────────────────────
# Must match the main backend — same project, same keys
# Get from: https://supabase.com → Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# ── JWT ───────────────────────────────────────────────────────
# Must match the main backend so tokens are cross-compatible.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_long_random_string_minimum_32_chars

# ── GEMINI AI ─────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...your_gemini_api_key
