# =============================================================
# Digital Chikitsak — Backend Environment Variables
# =============================================================
# HOW TO USE:
#   Local dev  → Copy this file to .env and fill in your values
#   Render.com → Add each variable in:
#                Dashboard → Your Service → Environment → Add Environment Variable
#
# NEVER commit your actual .env file to git.
# =============================================================


# ── SUPABASE ──────────────────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → API
# "Project URL" and "anon / public" key

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── CLOUDINARY ────────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
# Use the full CLOUDINARY_URL OR the three separate values — both work.
# On Render, set CLOUDINARY_URL (easiest single value).

CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Individual values (used if CLOUDINARY_URL is not set)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


# ── JWT ───────────────────────────────────────────────────────
# REQUIRED for production — generate a strong random secret.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
# On Render: set this as a Secret File or Environment Variable.

JWT_SECRET=replace_with_a_long_random_string_minimum_32_chars
JWT_ALG=HS256


# ── GEMINI AI (fallback when LM Studio is offline) ────────────
# Get from: https://aistudio.google.com/app/apikey
# LM Studio only works locally — on Render, Gemini is the AI engine.

GEMINI_API_KEY=AIzaSy...your_gemini_api_key


# ── LM STUDIO (local dev only — leave blank on Render) ────────
# Only works when running locally. On Render this is ignored
# because LM Studio is not available on cloud servers.

LMSTUDIO_URL=http://127.0.0.1:1234/v1/chat/completions
DEFAULT_MODEL=qwen3


# ── DISEASE PREDICTION MODEL ──────────────────────────────────
# Path to the trained joblib model file.
# On Render this path is relative to the working directory.

MODEL_PATH=models/disease_model.joblib


# ── FLASK ─────────────────────────────────────────────────────
# IMPORTANT: Set FLASK_ENV=production and FLASK_DEBUG=False on Render.

FLASK_ENV=production
FLASK_DEBUG=False


# =============================================================
# RENDER.COM DEPLOYMENT CHECKLIST
# =============================================================
# Service type : Web Service
# Runtime      : Python 3
# Build command: pip install -r requirements.txt
# Start command: gunicorn app:app --bind 0.0.0.0:$PORT --workers 2 --timeout 120
#
# Required env vars on Render (mark these as Secret):
#   ✅ SUPABASE_URL
#   ✅ SUPABASE_PUBLISHABLE_KEY
#   ✅ CLOUDINARY_URL            ← single value, easiest
#   ✅ JWT_SECRET                ← generate a strong random value
#   ✅ GEMINI_API_KEY
#   ✅ MODEL_PATH=models/disease_model.joblib
#   ✅ FLASK_ENV=production
#   ✅ FLASK_DEBUG=False
#
# Optional (leave blank or omit on Render):
#   ⬜ LMSTUDIO_URL              ← not available on cloud
#   ⬜ DEFAULT_MODEL             ← not used without LM Studio
# =============================================================
